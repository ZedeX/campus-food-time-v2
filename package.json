{
  "name": "campus-food-time",
  "version": "1.0.0",
  "description": "校园食光 - Campus Food Time: School cafeteria recipe publishing platform",
  "main": "worker/src/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply campus-food-data --local",
    "db:migrate:remote": "wrangler d1 migrations apply campus-food-data --remote",
    "db:seed": "wrangler d1 execute campus-food-data --local --file=worker/src/db/seed.sql"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "d1",
    "r2",
    "school",
    "recipe"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@playwright/test": "^1.61.0",
    "playwright": "^1.61.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
